# Copy to `.env` (git-ignored) for the full-stack docker-compose run. Do NOT commit real secrets.

# --- Postgres ---
POSTGRES_DB=shikhi
POSTGRES_USER=shikhi
POSTGRES_PASSWORD=change-me-strong-password

# --- Backend ---
# HS256 JWT signing key. MUST be >= 32 bytes and secret. Generate: openssl rand -base64 48
SHIKHI_JWT_SECRET=change-me-generate-a-real-48-byte-secret
# Comma-separated browser origins allowed to call the API cross-origin. Empty = same-origin
# only (correct for the compose stack, where nginx fronts both SPA and API).
SHIKHI_CORS_ORIGINS=
