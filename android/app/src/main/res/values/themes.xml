<resources>
    <!-- AppCompat parent is required by MainActivity (AppCompatActivity — the E13 per-app
         language backport applies locales through it on API < 33). Window chrome stays
         pinned to the light paper color exactly as before; Compose's ShikhiTheme owns all
         in-app colors, including dark. -->
    <style name="Theme.Shikhi" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">#FAF8F3</item>
        <item name="android:statusBarColor">#FAF8F3</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
