# Frontend build-time config (Vite). Copy to `.env` for local overrides, or set these as
# build environment variables in your host (e.g. Cloudflare Pages → Settings → Env vars).
#
# Empty / unset  → the SPA calls the API same-origin at /v1 (local dev uses the Vite proxy;
#                  the docker-compose stack uses nginx to front both SPA and API).
# Set it         → point the SPA at a DIFFERENT-origin backend (Option B: Cloudflare Pages
#                  front-end + Render back-end). No trailing slash. The backend must also list
#                  this SPA's origin in SHIKHI_CORS_ORIGINS or the browser will block requests.
#
# VITE_API_BASE_URL=https://shikhi-backend.onrender.com
